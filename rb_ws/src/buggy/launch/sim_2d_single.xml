<launch>

    <arg name="config_file" default="src/buggy/config/sim_single_sc.yaml"/>

    <node pkg="foxglove_bridge" exec="foxglove_bridge" name="foxglove" namespace="SC"/>

    <node pkg="buggy" exec="engine.py" name="SC_sim_single" namespace="SC">
        <param from="$(var config_file)"/>
    </node>
    <!-- To enable the ros2b node for measuring control latency, run this command in an ssh'd terminal:
    $ sudo socat -d -d PTY,raw,echo=0,link=/dev/ttyVirtual0,user=nand,mode=777 GOPEN:/dev/null,ignoreeof
    -->
    <!-- <node pkg="buggy" exec="ros_to_bnyahaj.py" name="SC_ros_to_bnyahaj" respawn="true" namespace="SC">
        <param from="$(var config_file)"/>
    </node> -->
    <node pkg="buggy" exec="buggy_state_converter.py" name="SC_state_converter" namespace="SC"/>
    <node pkg="buggy" exec="controller_node.py" name="SC_controller" namespace="SC">
        <param from="$(var config_file)"/>
    </node>
    <node pkg="buggy" exec="steer_offset_estimator.py" name="SC_offset_estimator" namespace="SC">
        <param from="$(var config_file)"/>
    </node>
</launch>